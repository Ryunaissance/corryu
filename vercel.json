{
  "outputDirectory": "output",
  "buildCommand": "python build_etf_pages.py",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/landing" },
    { "source": "/dashboard", "destination": "/index" },
    { "source": "/etf/:ticker", "destination": "/etf-detail?ticker=:ticker" }
  ]
}
